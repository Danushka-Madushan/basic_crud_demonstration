<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">
    <View
        android:id="@+id/status_bar_spacer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent" />
    <View
        android:id="@+id/view_header_bg"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@color/primaryRed"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/ic_menu"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="32dp"
        android:layout_marginStart="24dp"
        android:contentDescription="@string/hamburger_menu"
        android:src="@drawable/ic_menu"
        app:tint="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_greeting_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginStart="24dp"
        android:text="@string/hello_jane"
        android:textColor="@color/white"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/ic_menu"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_greeting_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/let_s_find_your_dream_job"
        android:textColor="@color/white"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/tv_greeting_title"
        app:layout_constraintStart_toStartOf="@id/tv_greeting_title" />


    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_search"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/white"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/view_header_bg"
        app:layout_constraintBottom_toBottomOf="@id/view_header_bg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_search"
                app:tint="@color/gray_tint" />

            <EditText
                android:id="@+id/et_search"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="12dp"
                android:background="@null"
                android:autofillHints="@null"
                android:hint="@string/search_jobs"
                android:textColorHint="#9E9E9E"
                android:textColor="#212121"
                android:inputType="text"
                android:maxLines="1"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>


    <com.google.android.material.card.MaterialCardView
        android:id="@+id/job_card_example"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="32dp"
        app:cardBackgroundColor="#F5F5F7"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/card_search">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <ImageView
                android:id="@+id/img_job_icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/user_image"
                android:src="@drawable/ic_people"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tv_job_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="8dp"
                android:text="@string/project_manager"
                android:textColor="@color/black_dimmed"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/img_job_icon"
                app:layout_constraintEnd_toStartOf="@id/btn_edit_job" />

            <androidx.constraintlayout.helper.widget.Flow
                android:id="@+id/flow_tags"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:constraint_referenced_ids="tag_type,tag_salary,tag_location"
                app:flow_wrapMode="chain"
                app:flow_horizontalStyle="packed"
                app:flow_horizontalBias="0.0"
                app:flow_horizontalGap="8dp"
                app:flow_verticalGap="8dp"
                app:layout_constraintTop_toBottomOf="@id/tv_job_title"
                app:layout_constraintStart_toStartOf="@id/tv_job_title"
                app:layout_constraintEnd_toStartOf="@id/btn_edit_job" />

            <TextView
                android:id="@+id/tag_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_round_tag"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="@string/full_time"
                android:textColor="@color/primaryRed"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tag_salary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_round_tag"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="@string/_20k_30k"
                android:textColor="@color/primaryRed"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tag_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_round_tag"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="@string/colombo"
                android:textColor="@color/primaryRed"
                android:textSize="12sp" />

            <ImageView
                android:id="@+id/btn_edit_job"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_round_tag"
                android:contentDescription="@string/edit_button"
                android:padding="8dp"
                android:src="@drawable/ic_edit"
                app:tint="@color/primaryRed"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>